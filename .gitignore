# Secrets (defensive)
*.pfx
*.snk
secrets.json
.env
.env.*

# Third-party tool binaries (xnbcli) — install locally via tools/install-xnbcli.ps1.
# README.txt and the .bat wrappers stay tracked; the binaries do not.
tools/xnbcli/xnbcli.exe
tools/xnbcli/*.node
tools/xnbcli/packed/
tools/xnbcli/unpacked/
