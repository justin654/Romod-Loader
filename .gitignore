TestResults/
*.trx
coverage/
*.coverage
*.coveragexml

# NuGet
*.nupkg
**/packages/

# OS
Thumbs.db
Desktop.ini
.DS_Store

# Logs / diagnostics
*.log
artifacts/diag/

# Optional API catalog tool output (when mod_probe is present)
